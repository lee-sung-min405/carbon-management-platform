// PCF 도메인의 영속 모델 정의.
//
// IMPLEMENTATION_PLAN.md 5장의 엔티티 정의를 그대로 반영한다.
// LifeCycleStage는 별도 테이블 대신 enum + src/domain/pcf/stages.ts 상수로 표현.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StageCode {
  RAW_MATERIAL
  PRODUCTION
  TRANSPORT
  USE
  END_OF_LIFE
}

enum GhgScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

model Product {
  id             String            @id @default(cuid())
  name           String
  sku            String?           @unique
  functionalUnit String
  description    String?
  createdAt      DateTime          @default(now())
  activities     ProductActivity[]
  runs           CalculationRun[]
}

model EmissionFactor {
  id         String            @id @default(cuid())
  name       String
  stageCode  StageCode
  scope      GhgScope          @default(SCOPE_3) // GHG 프로토콜 분류 (Scope 1/2/3)
  unit       String // "kgCO2e/kg", "kgCO2e/kWh", "kgCO2e/ton-km"
  value      Float
  source     String // 데모용 표기 포함 ("DEMO ONLY — not for certification")
  isDemo     Boolean           @default(true)
  version    Int               @default(1) // 계수 값 변경 이력 (장변 시 +1)
  validFrom  DateTime          @default(now()) // 이 계수가 적용되는 시작 시점
  validTo    DateTime? // 장변으로 종료되면 이전 row의 validTo 채움
  activities ProductActivity[]

  @@unique([name, stageCode, version])
  @@index([stageCode])
  @@index([stageCode, scope])
}

model ProductActivity {
  id              String         @id @default(cuid())
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  stageCode       StageCode
  name            String
  amount          Float // 비-운송: 활동량 / 운송: ton-km 직접 또는 0(파생 모드)
  unit            String
  factor          EmissionFactor @relation(fields: [factorId], references: [id])
  factorId        String
  allocationRatio Float          @default(1.0) // 0 < x <= 1
  weightKg        Float? // TRANSPORT 파생 모드 전용
  distanceKm      Float? // TRANSPORT 파생 모드 전용
  occurredOn      DateTime?      @db.Date // 활동 발생일 (자료 임포트/시계열 차트용)
  note            String?
  createdAt       DateTime       @default(now())

  @@index([productId])
  @@index([factorId])
  @@index([productId, occurredOn])
}

model CalculationRun {
  id           String            @id @default(cuid())
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  totalKgCO2e  Float
  snapshotJson Json // 계산 시점의 활동/계수 스냅샷
  runAt        DateTime          @default(now())
  items        CalculationItem[]

  @@index([productId, runAt])
}

model CalculationItem {
  id         String         @id @default(cuid())
  run        CalculationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  activityId String
  stageCode  StageCode
  scope      GhgScope       @default(SCOPE_3) // 참조 factor의 scope 스냅샷 (Scope 단위 집계용)
  kgCO2e     Float
  share      Float // 0~1

  @@index([runId])
}
